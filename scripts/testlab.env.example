# Test Lab credentials — copy this file to `testlab.env` (gitignored) and fill in.
# Robo signs in with this account before crawling, so use a disposable TEST account,
# never a real user's. The existing free-tier test account works:
#   BUDGETTY_TEST_EMAIL=kamen.kostov94+budgetty@gmail.com
#   BUDGETTY_TEST_PASSWORD=...
BUDGETTY_TEST_EMAIL=
BUDGETTY_TEST_PASSWORD=
